<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet xml:id="act0">
  <title>🏫 Activity 0 - Review</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      This iactivity is due at the beginning of class on <alert>Wednesday, July 1</alert>. Please write all solutions on this sheet. If you need additional space, you may attach additional work to this sheet, but please clearly label your work with its corresponding problem. 
    </p>
  </introduction>

  <!-- Exercises start here. -->
  <sidebyside>
    <exercise workspace="1in">
      <statement>
        <p>
          Use substitution to compute <md> \int \frac{1}{3x+2} \, dx. </md>
        </p>
      </statement>
    </exercise>

    <exercise workspace="1in">
      <statement>
        <p>
          Use substitution to compute <md> \int_1^2 x^3 \cos(x^4 + 3) \, dx. </md>
        </p>
      </statement>
    </exercise>
  </sidebyside>

  <sidebyside>
    <exercise workspace="1in">
      <statement>
        <p>
          Use integration by parts to compute  <md> \int xe^{-x} \, dx. </md>
        </p>
      </statement>
    </exercise>

    <exercise workspace="1in">
      <statement>
        <p>
          Use integration by parts to compute <md> \int_{\frac{\pi}{12}}^{\frac{\pi}{6}} x^2 \cos(3x) \, dx. </md>
        </p>
      </statement>
    </exercise>
  </sidebyside>

  <exercise workspace="2in">
    <statement>
      <p>
        Use partial fraction decomposition to compute <md> \int \frac{3x+11}{x^2 - x - 6} \, dx </md>. 
      </p>
    </statement>
  </exercise>

  <exercise workspace="3in">
    <statement>
      <p>
        Write the system of equations <md> \begin{cases} x = y + z \\ x + y + z = 3 \\ x + 3z = 1 \end{cases} </md> as an augmented matrix. Then solve the system with Gaussian elimination (elementary row operations). 
      </p>
    </statement>
  </exercise>

</worksheet>
