<?xml version="1.0" encoding="UTF-8"?>

<worksheet xml:id="a4">
  <title>🏫 Activity 4 - Solving Higher-Order Linear Equations </title>

  <introduction>
    <p>
      <alert>Instructions:</alert> Write solutions to each of the following problems in the space provided. You are encouraged to work in groups, but also encouraged to use your own words to express your ideas. This activity is due at the beginning of class on <alert>Wednesday, July 15</alert>.
    </p>
  </introduction>

    <!-- Problem 1 -->
    <exercise workspace="4in">
        <statement>
            <p>
                When finding a complementary solution to an <m>n</m>th-order linear nonhomogeneous equation, we first find roots of the characteristic polynomial <m>\lambda_1, \ldots, \lambda_n</m>. We saw that these roots produce the fundamental solutions to the complementary equation. Summarize the different cases we may have for these roots and how they impact the structure of the complementary solution. 
            </p>
        </statement>
    </exercise>



    <!-- Problem 2 -->
    <exercise>
        <introduction>
            <p>
                Consider the differential equation <md xml:id="a4-prob1">
                    u''' - 2u'' - u' + 2u = 2t^2 + 4t - 9.
                </md>
            </p>
        </introduction>

        <task workspace="0.5in">
            <statement>
                <p>
                    Find the complementary solution. 
                </p>
            </statement>
        </task>

        <task workspace="2in">
            <statement>
                <p>
                    Use annihilators to find the form of the particular solution.
                </p>
            </statement>
        </task>

        <task workspace="2in">
            <statement>
                <p>
                    Find a particular solution using the method of undetermined coefficients. 
                </p>
            </statement>
        </task>

        

        <task workspace="6in">
            <statement>
                <p>
                    Find a particular solution using variation of parameters. You may use wolframalpha to assist with integrals and determinants. 
                </p>
            </statement>
        </task>

        <task workspace="0.5in">
            <statement>
                <p>
                    Write down the general solution. 
                </p>
            </statement>
        </task>
    </exercise>



    <!-- Problem 3 -->
    <exercise>
        <introduction>
            <p>
                Consider the differential equation <md xml:id="a4-prob2"> y'' - 4y' + 4y = 7 \sin(t) - \cos(t).</md> 
            </p>
        </introduction>

        <task workspace="0.5in">
            <p>
                Find the complementary solution. 
            </p>
        </task>

        <task workspace="2in">
            <statement>
                <p>
                    Use annihilators to find the form of the particular solution. 
                </p>
            </statement>
        </task>

        <task workspace="2in">
            <statement>
                <p>
                    Find a particular solution using the method of undetermined coefficients. 
                </p>
            </statement>
        </task>

        

        <task workspace="5in">
            <statement>
                <p>
                    Find a particular solution using variation of parameters. You may use wolframalpha to assist with integrals and determinants. 
                </p>
            </statement>
        </task>

        <task workspace="0.5in">
            <statement>
                <p>
                    Write down the general solution. 
                </p>
            </statement>
        </task>
    </exercise>

    <!-- Problem 4 -->
    <exercise workspace="0.5in">
        <statement>
            <p>
                If problems 2 &amp; 3 were exam questions, and you were able to use any method of your choice, which would you chose and why?
            </p>
        </statement>
        <hint>
            <p>
                These can be personal opinions ;D. 
            </p>
        </hint>
    </exercise>
    
</worksheet>




