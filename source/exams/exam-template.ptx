<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="examx">
  <title>Exam Example </title>
  <introduction>
    <p>
      <alert>Instructions:</alert> You have 110 minutes to complete this exam. There is a multiple choice section and free response section. You may use your prep work journals as a reference on this exam provided they have been cleared with the instructor before beginning the exam. Use of a scientific calculator is permitted, but not necessary. No other notes or electronic devices of any kind will be allowed on this exam. Failure to comply with this policy may result in earning no credit for any portion of this exam (up to and including all credit) as well as a report to the university for academic misconduct. 
    </p>
  </introduction>

  <worksheet xml:id="examx-mc">
    <title>Multiple-Choice</title>
    <exercisegroup>
        <introduction>
            <p>
                <alert>For problems 1-2:</alert> consider the differential equation <md>
                \frac{d^2y}{dx^2} - 2x \frac{dy}{dx} + 2y = 0.
                </md>
            </p>
        </introduction>

        <exercise>
            <statement>
                <p>
                    What is the order of the differential equation?
                </p>
            </statement>
            <choices>
                <choice >
                    <statement>
                        <p> 0 </p>
                    </statement>
                </choice>
                <choice >
                    <statement>
                        <p> 1 </p>
                    </statement>
                </choice>
                <choice>
                    <statement>
                        <p> 2 </p>
                    </statement>
                </choice>
                <choice>
                    <statement>
                        <p> 3 </p>
                    </statement>
                </choice>
            
            </choices>
        </exercise>

        <exercise>
            <statement>
                <p>
                    Which of the following descriptions do NOT apply to the given differential equation?
                </p>
            </statement>
            <choices>
                <choice>
                    <statement>
                        <p> Linear </p>
                    </statement>
                </choice>
                <choice >
                    <statement>
                        <p> Homogeneous </p>
                    </statement>
                </choice>
                <choice>
                    <statement>
                        <p> Partial </p>
                    </statement>
                </choice>
                <choice>
                    <statement>
                        <p> Standard Form </p>
                    </statement>
                </choice>
            
            </choices>
        </exercise>
    </exercisegroup>
  </worksheet>
</section>