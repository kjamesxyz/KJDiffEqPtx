            </p>
</subsection>

    <worksheet xml:id="hw2-assigned">
        <title>Assigned Problems</title>
        <introduction>
            <p>
                <alert>Instructions:</alert> Write solutions to the following problems in the space provided. If you need additional space, you may attach scratch work to the back of this sheet. Please be sure any additional work is clearly labeled with the question it corresponds to.
            </p>
        </introduction>
        <exercise workspace="2in">
            <introduction>
                <p>
                    Classify each of the following equations as linear, separable, exact, or homogeneous. Note that some equations may be more than one kind. Then find a general solution using any appropriate method.
                </p>
            </introduction>

            <task>
                <statement>
                    <p>
                        <m>\dydx = \frac{x-y}{x}</m>
                    </p>
                </statement>
            </task>

            <task>
                <statement>
                    <p>
                        <m>\left(x^2 + \frac{2y}{x} \right) dx = (3 - \ln(x^2)) dy</m>
                    </p>
                </statement>
            </task>

            <task>
                <statement>
                    <p>
                        <m>\frac{y}{x^2} \dydx + e^{2x^3 + y^2} = 0</m>
                    </p>
                </statement>
            </task>

            <task>
                <statement>
                    <p>
                        <m>t \dot{x} - (1+t)x = tx^2 </m>
                    </p>
                </statement>
            </task>
        </exercise>
    </worksheet>
    
</section>