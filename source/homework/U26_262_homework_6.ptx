<?xml version="1.0" encoding="UTF-8"?>

<worksheet xml:id="hw6">
    <title>📝 Homework 6</title>
    <introduction>
        <p>
            <alert>Instructions:</alert> This assignment is due <alert>Monday, July 20</alert>. Write solutions to the following problems in the space provided. If you need additional space, you may attach scratch work to the back of this sheet. Please be sure any additional work is clearly labeled with the question it corresponds to.
        </p>
    </introduction>

    <exercise workspace="6in">
        <statement>
            <p>
                Find two power series solutions centered about the point <m> x = 0 </m> for the ODE <md> y'' + 4y' + 5y = 0.</md> Write the first 3 terms of each solution. 
            </p>
        </statement>
    </exercise>

    <exercise workspace="6in">
        <statement>
            <p>
                Find a power series solution for the IVP <md> (x^2 + 1)y'' + 2xy' = 0; \hspace{10pt} y(0) = y'(0) = 1</md>
            </p>
        </statement>
    </exercise>

    <exercise workspace="6in">
        <statement>
            <p>
                Find a general power series solution on <m>(0,\infty)</m> for the ODE <md> 2xy'' - (3 + 2x)y' + y = 0 </md>
            </p>
        </statement>
    </exercise>

</worksheet>
